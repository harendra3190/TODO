<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="container">
    <h1>Edit Task</h1>

    <form action="/todos/<%= todo._id %>?_method=PUT" method="POST">
        
        <!-- Title -->
        <input 
            type="text" 
            name="title" 
            value="<%= todo.title %>" 
            placeholder="Enter title"
            required
        >

        <!-- Description -->
        <input 
            type="text" 
            name="description" 
            value="<%= todo.description %>" 
            placeholder="Enter description"
            required
        >

        <!-- Completed -->
        <label>
            <input 
                type="checkbox" 
                name="completed" 
                <%= todo.completed ? "checked" : "" %>
            >
            Completed
        </label>

        <br><br>

        <button type="submit">Update</button>
    </form>
</div>

</body>
</html>