<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="container">
    <h1>Add Task</h1>

    <form action="/todos" method="POST">
        
        <!-- Title -->
        <input 
            type="text" 
            name="title" 
            placeholder="Enter title" 
            required
        >

        <!-- Description -->
        <input 
            type="text" 
            name="description" 
            placeholder="Enter description" 
            required
        >

        <button type="submit">Add</button>
    </form>
</div>

</body>
</html>